<launch>
    <!-- Python (rospy) SE(3)-LIO node — mirrors run_se3lio_*.launch for the C++ node.
         Reads the dataset yaml via ~config_file (same root config/ the C++ node loads). -->
    <arg name="config" default="$(find se3_lio)/../config/ntu.yaml"/>
    <arg name="use_sim_time" default="false"/>
    <arg name="rviz" default="false"/>

    <param name="use_sim_time" value="$(arg use_sim_time)"/>

    <node pkg="se3_lio" type="se3_lio_node.py" name="se3_lio_node" output="screen">
        <param name="config_file" value="$(arg config)"/>
    </node>

    <node if="$(arg rviz)" pkg="rviz" type="rviz" name="rviz"
          args="-d $(find se3_lio)/ros1/rviz/rviz.rviz" output="screen"/>
</launch>
