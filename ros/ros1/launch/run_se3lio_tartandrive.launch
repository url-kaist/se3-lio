<launch>
    <!--Set true when replaying a rosbag with the clock flag (rosbag play, clock enabled); keep false for live sensors-->
    <arg name="use_sim_time" default="false"/>
    <param name="use_sim_time" value="$(arg use_sim_time)"/>

    <!--Load parameters from tartandrive.yaml-->
    <rosparam command="load" file="$(find se3_lio)/ros1/config/tartandrive.yaml"/>

    <!--Run the lio_node (build with -DLIDAR_TYPE=velodyne)-->
    <node pkg="se3_lio" type="lio_node" name="lio_node" output="screen"/>

    <!--Launch RViz for visualization-->
    <node pkg="rviz" type="rviz" name="rviz" args="-d $(find se3_lio)/ros1/rviz/rviz.rviz" output="screen"/>
</launch>
